<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" alignment="CENTER" 
      xmlns="http://javafx.com/javafx/8" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="application.PedidosController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    
    <Label text="GESTIÓN DE PEDIDOS - SHOE TEC" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #8B4513;"/>
    
    <HBox spacing="15" alignment="BOTTOM_LEFT" style="-fx-background-color: #f4f4f4; -fx-padding: 10; -fx-background-radius: 5;">
        <VBox spacing="5">
            <Label text="Cliente:" style="-fx-font-weight: bold;"/>
            <ComboBox fx:id="comboClientes" prefWidth="200" promptText="Seleccionar Cliente..."/>
        </VBox>
        
        <VBox spacing="5">
            <Label text="Servicio a realizar:" style="-fx-font-weight: bold;"/>
            <ComboBox fx:id="comboServicios" prefWidth="250" promptText="Seleccionar Servicio..."/>
        </VBox>

        <Button text="FINALIZAR PEDIDO" onAction="#finalizarPedido" 
                style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-min-height: 30;"/>
        
        <Button fx:id="btnEntregar" text="ENTREGAR SELECCIONADO" onAction="#entregarPedido" 
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-min-height: 30;" />
                
         <Button fx:id="btnTaller" text="ENVIAR A TALLER" onAction="#marcarEnTaller" 
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-min-height: 30;" />
                       
    </HBox>
    <Separator/>

    <VBox spacing="5" VBox.vgrow="ALWAYS">
        <Label text="Historial de Pedidos registrados:" style="-fx-font-weight: bold;"/>
        <TableView fx:id="tablaPedidos" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="50" />
                <TableColumn fx:id="colFecha" text="Fecha" prefWidth="150" />
                <TableColumn fx:id="colCliente" text="ID Cliente" prefWidth="100" />
                <TableColumn fx:id="colEstado" text="Estado" prefWidth="100" />
                <TableColumn fx:id="colPrecio" text="Total (€)" prefWidth="100" />
            </columns>
        </TableView>
        <Button text="Refrescar Historial" onAction="#cargarPedidos" maxWidth="Infinity" style="-fx-margin-top: 10;"/>
    </VBox>
</VBox>