<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" alignment="CENTER" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.AlmacenController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    
    <Label text="CONTROL DE EXISTENCIAS (ALMACÉN)" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #8B4513;"/>
    
    <VBox spacing="10" style="-fx-background-color: #F9F4ED; -fx-border-color: #D2B48C; -fx-border-radius: 5; -fx-background-radius: 5;">
        <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
        <Label text="Registrar Nuevo Material" style="-fx-font-weight: bold; -fx-text-fill: #5D4037;"/>
        <GridPane hgap="10" vgap="10">
            <columnConstraints>
                <ColumnConstraints minWidth="100" prefWidth="120" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            <Label text="Nombre Material:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="txtNombre" promptText="Ej: Cuero Vacuno" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
            <Label text="Stock / Cantidad:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="txtStock" promptText="Ej: 50" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            <Label text="Proveedor:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="txtProveedor" promptText="Ej: Curtidos Martínez" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            <Button text="📦 Registrar Material" onAction="#guardarMaterial" 
                    GridPane.rowIndex="3" GridPane.columnIndex="1" 
                    style="-fx-background-color: #8B4513; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
        </GridPane>
    </VBox>

    <Separator />
    
    <TableView fx:id="tablaMateriales" prefHeight="400">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50" />
            <TableColumn fx:id="colNombre" text="Material" prefWidth="150" />
            <TableColumn fx:id="colProveedor" text="Proveedor" prefWidth="150" /> 
            <TableColumn fx:id="colStock" text="Stock Actual" prefWidth="100" />
            <TableColumn fx:id="colMinimo" text="Stock Mínimo" prefWidth="100" />
        </columns>
    </TableView>
    
    <Button text="Actualizar Stock" onAction="#cargarMateriales" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;"/>
</VBox>